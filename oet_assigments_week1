    </div>

    <script>
        // CONFIGURACIÓN DE FECHA ACTUAL
        // Utilizamos la fecha simulada proveída en el sistema: 10 de Julio de 2026
        const currentDate = new Date('2026-07-10T10:50:23');
        let overrideActive = false;

        function checkDateLocks() {
            const tabs = document.querySelectorAll('.tab-content');
            tabs.forEach(tab => {
                const unlockDateStr = tab.getAttribute('data-date');
                if (!unlockDateStr) return;
                
                const unlockDate = new Date(unlockDateStr + 'T00:00:00');
                const lockedMsg = tab.querySelector('.locked-message');
                const taskContent = tab.querySelector('.task-content');

                if (currentDate >= unlockDate || overrideActive) {
                    lockedMsg.style.display = 'none';
                    taskContent.style.display = 'block';
                } else {
                    lockedMsg.style.display = 'block';
                    taskContent.style.display = 'none';
                }
            });
        }

        // LÓGICA DE TABS Y MOSTRAR AUDIO GLOBAL
        function openTab(evt, tabName, requiredDate) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].style.display = "none";
                tabcontent[i].classList.remove("active");
            }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) {
                tablinks[i].classList.remove("active");
            }
            document.getElementById(tabName).style.display = "block";
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");

            // Mostrar el reproductor de audio global SOLO en Lunes, Martes y Miércoles
            const globalAudio = document.getElementById('global-audio-container');
            const unlockDate = new Date(requiredDate + 'T00:00:00');
            
            if ((tabName === 'lunes' || tabName === 'martes' || tabName === 'miercoles') && (currentDate >= unlockDate || overrideActive)) {
                globalAudio.style.display = 'flex';
            } else {
                globalAudio.style.display = 'none';
                document.getElementById('oet-audio-player').pause();
            }
        }

        // CONTROL DE REPRODUCCIÓN (Evitar que escuchen las respuestas)
        const audioEl = document.getElementById('oet-audio-player');
        audioEl.addEventListener('timeupdate', function() {
            // El prompt pide cortar las respuestas que inician en 36:36 (2196 segundos)
            if (this.currentTime >= 2196) {
                this.pause();
                this.currentTime = 2195;
                alert("⚠️ Has alcanzado el final de la prueba. El audio se ha detenido antes de las respuestas.");
            }
        });

        function jumpAudio(seconds) {
            audioEl.currentTime = seconds;
            audioEl.play();
        }

        // FUNCIÓN TEACHER OVERRIDE
        function unlockAll() {
            overrideActive = true;
            checkDateLocks();
            alert("🔓 Modo Profesor Activado: Todas las asignaciones han sido desbloqueadas para su revisión.");
            // Refrescar visibilidad de audio si estamos en una pestaña requerida
            const activeTab = document.querySelector('.tab-btn.active').getAttribute('onclick');
            if (activeTab.includes('lunes') || activeTab.includes('martes') || activeTab.includes('miercoles')) {
                document.getElementById('global-audio-container').style.display = 'flex';
            }
        }

        // GENERACIÓN DEL PDF
        function generatePDF() {
            alert("Preparando documento... Su navegador abrirá el cuadro de diálogo de impresión. Guarde el archivo como PDF.");
            // Utilizamos el motor de impresión del navegador junto con CSS @media print
            // para ocultar la UI y dejar solo las respuestas
            window.print();
        }

        // Inicializar bloqueos al cargar
        checkDateLocks();
    </script>
</body>
</html>
