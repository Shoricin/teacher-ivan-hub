        .container { max-width: 900px; margin: 0 auto; padding: 2rem; }

        /* Tabs System */
        .tab-container { display: flex; flex-wrap: wrap; border-bottom: 3px solid var(--gris-neutro); margin-bottom: 2rem; }
        .tab-btn {
            background: transparent; border: none; padding: 15px 25px; font-family: var(--font-titulares);
            font-size: 1rem; color: var(--gris-neutro); cursor: pointer; transition: all 0.3s;
            font-weight: 700; border-bottom: 4px solid transparent; margin-bottom: -3px;
        }
        .tab-btn.active { color: var(--azul-primario); border-bottom: 4px solid var(--naranja-vibrante); }
        .tab-content { display: none; animation: fadeIn 0.4s ease; }
        .tab-content.active { display: block; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Cards & Forms */
        .section-card {
            background: var(--blanco-puro); border-radius: 12px; padding: 2.5rem;
            box-shadow: 0 10px 30px rgba(10, 70, 140, 0.08); border-top: 5px solid var(--naranja-vibrante);
            margin-bottom: 2rem;
        }
        .locked-overlay {
            text-align: center; padding: 4rem 2rem; background: #f8fafc; border-radius: 8px;
            border: 2px dashed var(--gris-neutro);
        }
        .locked-overlay h3 { color: var(--gris-neutro); font-size: 1.8rem; margin-bottom: 10px; }
        
        .video-container { position: relative; padding-bottom: 56.25%; height: 0; border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem; }
        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
        
        .audio-player-container {
            background: #eef2f6; padding: 15px; border-radius: 8px; margin-bottom: 1.5rem;
            display: flex; flex-direction: column; align-items: center; border: 1px solid var(--gris-neutro);
        }
        audio { width: 100%; outline: none; }

        .btn {
            background: var(--azul-primario); color: white; border: none; padding: 12px 25px;
            border-radius: 5px; font-family: var(--font-titulares); cursor: pointer; transition: 0.3s;
            font-size: 1rem; text-transform: uppercase;
        }
        .btn:hover { background: #08366b; }
        .btn-pdf { background: #4CAF50; width: 100%; margin-top: 2rem; font-size: 1.2rem; }
        .btn-pdf:hover { background: #388E3C; }

        /* OET Specific Styles */
        .question-line { margin-bottom: 12px; font-size: 0.95rem; line-height: 1.8; }
        .oet-input { border: none; border-bottom: 2px solid var(--gris-neutro); padding: 5px; width: 150px; font-family: var(--font-cuerpo); font-weight: 600; color: var(--azul-primario); outline: none; background: transparent; }
        .oet-input:focus { border-color: var(--naranja-vibrante); }
        
        .mcq-block { margin-bottom: 1.5rem; background: #fafafa; padding: 15px; border-radius: 8px; border: 1px solid #eee; }
        .mcq-question { font-weight: 700; margin-bottom: 10px; font-size: 1rem; }
        .mcq-option { display: block; margin-bottom: 8px; font-size: 0.95rem; cursor: pointer; }

        /* Estilos de Impresión para el PDF */
        @media print {
            body { padding: 0; background: white; }
            .hero, .tab-container, .audio-player-container, .video-container, .btn, .teacher-override { display: none !important; }
